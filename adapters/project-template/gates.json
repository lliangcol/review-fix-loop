{
  "version": 1,
  "rule_files": ["adapters/project-template/SKILL.md"],
  "modes": {
    "normal_loop": {
      "scope": ["staged", "unstaged", "untracked"],
      "require_fresh_snapshot": true
    },
    "large_merge": {
      "baseline": "origin/main",
      "scope": ["merge_base_to_head", "staged", "unstaged", "untracked"],
      "requires_merge_base": true,
      "requires_residual_risk_report": true,
      "require_risk_slices": true,
      "require_invariant_checks": true,
      "require_residual_risk_report": true,
      "max_changed_files": 80,
      "max_deep_review_files": 80,
      "max_diff_bytes_per_slice": 250000
    },
    "docs_only": {
      "scope": ["staged", "unstaged", "untracked"],
      "requires_repo_map": false,
      "max_changed_files": 25
    }
  },
  "slices": [
    {
      "id": "source",
      "paths": ["src/**", "lib/**"],
      "risk": "high"
    },
    {
      "id": "docs",
      "paths": ["docs/**", "README.md"],
      "risk": "medium"
    },
    {
      "id": "tests",
      "paths": ["tests/**"],
      "risk": "medium"
    },
    {
      "id": "project-config",
      "paths": [".github/**", ".gitignore", "pyproject.toml", "MANIFEST.in", "package.json", "package-lock.json", "pnpm-lock.yaml", "yarn.lock"],
      "risk": "medium"
    },
    {
      "id": "tools",
      "paths": ["tools/**", "scripts/**"],
      "risk": "medium"
    }
  ],
  "gates": [
    {
      "id": "working-tree-whitespace",
      "argv": ["git", "diff", "--check"],
      "command": "git diff --check",
      "scope": "unstaged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "staged-whitespace",
      "argv": ["git", "diff", "--cached", "--check"],
      "command": "git diff --cached --check",
      "scope": "staged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "branch-whitespace",
      "argv": ["git", "diff", "--check", "{merge_base}..HEAD"],
      "command": "git diff --check {merge_base}..HEAD",
      "scope": "merge_base_to_head",
      "modes": ["large_merge"],
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 120,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "untracked-whitespace",
      "argv": ["__builtin__:untracked-whitespace"],
      "command": "builtin untracked whitespace check",
      "scope": "untracked",
      "filter_mode": "file",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    }
  ]
}
