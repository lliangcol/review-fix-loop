{
  "version": 1,
  "rule_files": [],
  "modes": {
    "normal_loop": {
      "scope": ["staged", "unstaged", "untracked"],
      "require_fresh_snapshot": true
    },
    "large_merge": {
      "baseline": "origin/main",
      "scope": ["merge_base_to_head", "staged", "unstaged", "untracked"],
      "require_risk_slices": true,
      "require_invariant_checks": true,
      "require_residual_risk_report": true
    }
  },
  "slices": [
    {
      "id": "source",
      "paths": ["src/**", "*.py"],
      "risk": "medium"
    },
    {
      "id": "tests",
      "paths": ["tests/**"],
      "risk": "low"
    },
    {
      "id": "packaging",
      "paths": ["pyproject.toml", "setup.cfg", "setup.py", "MANIFEST.in"],
      "risk": "medium"
    },
    {
      "id": "docs",
      "paths": ["README.md", "docs/**"],
      "risk": "low"
    }
  ],
  "gates": [
    {
      "id": "working-tree-whitespace",
      "argv": ["git", "diff", "--check"],
      "command": "git diff --check",
      "scope": "unstaged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "staged-whitespace",
      "argv": ["git", "diff", "--cached", "--check"],
      "command": "git diff --cached --check",
      "scope": "staged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "untracked-whitespace",
      "argv": ["__builtin__:untracked-whitespace"],
      "command": "builtin untracked whitespace check",
      "scope": "untracked",
      "filter_mode": "file",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "pytest",
      "argv": ["python", "-m", "pytest", "-q"],
      "command": "python -m pytest -q",
      "scope": "all",
      "when_paths": ["src/**", "tests/**", "*.py"],
      "filter_mode": "nofilter",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 300,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "project test command declared by adapter",
      "parser": {
        "type": "exit-code"
      }
    },
    {
      "id": "build-check",
      "argv": ["python", "-m", "build"],
      "command": "python -m build",
      "scope": "all",
      "when_paths": ["pyproject.toml", "setup.cfg", "setup.py", "MANIFEST.in"],
      "filter_mode": "nofilter",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 300,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "project build command declared by adapter",
      "parser": {
        "type": "exit-code"
      }
    }
  ]
}
