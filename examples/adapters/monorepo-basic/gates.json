{
  "version": 1,
  "rule_files": [],
  "modes": {
    "normal_loop": {
      "scope": ["staged", "unstaged", "untracked"],
      "require_fresh_snapshot": true
    },
    "large_merge": {
      "baseline": "origin/main",
      "scope": ["merge_base_to_head", "staged", "unstaged", "untracked"],
      "require_risk_slices": true,
      "require_invariant_checks": true,
      "require_residual_risk_report": true,
      "max_deep_review_files": 80,
      "max_diff_bytes_per_slice": 250000
    }
  },
  "slices": [
    {
      "id": "backend",
      "paths": ["services/api/**", "packages/backend/**"],
      "risk": "high"
    },
    {
      "id": "frontend",
      "paths": ["apps/web/**", "packages/frontend/**"],
      "risk": "medium"
    },
    {
      "id": "shared",
      "paths": ["packages/shared/**"],
      "risk": "high"
    },
    {
      "id": "docs",
      "paths": ["README.md", "docs/**"],
      "risk": "low"
    }
  ],
  "gates": [
    {
      "id": "working-tree-whitespace",
      "argv": ["git", "diff", "--check"],
      "command": "git diff --check",
      "scope": "unstaged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "staged-whitespace",
      "argv": ["git", "diff", "--cached", "--check"],
      "command": "git diff --cached --check",
      "scope": "staged",
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "branch-whitespace",
      "argv": ["git", "diff", "--check", "{merge_base}..HEAD"],
      "command": "git diff --check {merge_base}..HEAD",
      "scope": "merge_base_to_head",
      "modes": ["large_merge"],
      "filter_mode": "diff_context",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 120,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "read-only git diff whitespace check",
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "untracked-whitespace",
      "argv": ["__builtin__:untracked-whitespace"],
      "command": "builtin untracked whitespace check",
      "scope": "untracked",
      "filter_mode": "file",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 60,
      "parallel_safe": true,
      "reads_worktree_only": true,
      "parser": {
        "type": "git-diff-check"
      }
    },
    {
      "id": "backend-tests",
      "argv": ["python", "-m", "pytest", "services/api/tests", "packages/backend/tests", "-q"],
      "command": "python -m pytest services/api/tests packages/backend/tests -q",
      "scope": "all",
      "when_paths": ["services/api/**", "packages/backend/**", "packages/shared/**"],
      "filter_mode": "nofilter",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 600,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "project backend tests declared by adapter",
      "parser": {
        "type": "exit-code"
      }
    },
    {
      "id": "frontend-tests",
      "argv": ["corepack", "pnpm", "--filter", "web", "test"],
      "command": "corepack pnpm --filter web test",
      "scope": "all",
      "when_paths": ["apps/web/**", "packages/frontend/**", "packages/shared/**"],
      "filter_mode": "nofilter",
      "fail_level": "error",
      "blocking": true,
      "timeout_seconds": 600,
      "trusted": true,
      "allow_in_ci": true,
      "writes_worktree": false,
      "requires_network": false,
      "trust_reason": "project frontend tests declared by adapter",
      "parser": {
        "type": "exit-code"
      }
    }
  ]
}
