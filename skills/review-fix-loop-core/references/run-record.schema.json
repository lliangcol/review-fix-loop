{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Fix Loop Run Record",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "mode",
    "pass",
    "snapshot_id",
    "config_hash",
    "rule_hashes",
    "must_reload",
    "reloaded_slices",
    "reused_slices",
    "planned_gates",
    "fixes",
    "diagnostics",
    "gates",
    "stop_decision",
    "residual_risks"
  ],
  "properties": {
    "schema": { "const": 1 },
    "run_id": { "type": "string" },
    "mode": { "type": "string" },
    "pass": { "type": "integer" },
    "snapshot_id": { "type": "string" },
    "final_pass": { "type": "boolean" },
    "config_hash": { "type": "string" },
    "config_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "local_override_applied": { "type": "boolean" },
    "local_override_available": { "type": "boolean" },
    "local_override_disabled": { "type": "boolean" },
    "local_override_path": { "type": ["string", "null"] },
    "rule_hashes": { "type": "object" },
    "must_reload": { "type": "array" },
    "reloaded_slices": { "type": "array" },
    "reused_slices": { "type": "array" },
    "planned_gates": { "type": "array" },
    "fixes": { "type": "array" },
    "diagnostics": { "type": "array" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "exit_code", "duration_ms"]
      }
    },
    "stop_decision": { "enum": ["continue", "stop", "blocked"] },
    "residual_risks": { "type": "array" }
  }
}
